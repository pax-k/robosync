{
  "name": "mdsync",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "pnpm run test:scripts && turbo run test",
    "test:unit": "pnpm run test:scripts && turbo run test --filter='./packages/*' --filter='./apps/*'",
    "test:ha2ha-packages": "node scripts/ha2ha-package-smoke.mjs && node scripts/ha2ha-skill-package-smoke.mjs && node scripts/ha2ha-client-package-smoke.mjs",
    "test:mdsync-packages": "node scripts/mdsync-client-package-smoke.mjs && node scripts/mdsync-skill-package-smoke.mjs",
    "test:integration": "turbo run test:integration --filter='@mdsync/db' --filter='@ha2ha/http'",
    "test:e2e": "playwright test",
    "test:scripts": "tsx --test scripts/*.test.mjs scripts/**/*.test.mjs",
    "dev:web": "pnpm --filter web run dev:bare",
    "dev:server": "turbo run dev -F server",
    "db:generate": "turbo run db:generate -F @mdsync/db",
    "deploy": "turbo run deploy -F @mdsync/infra",
    "deploy:server": "pnpm --filter @mdsync/infra run deploy:server",
    "destroy": "turbo run destroy -F @mdsync/infra",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@mdsync/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@cloudflare/workers-types": "catalog:",
    "@mdsync/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.13.14",
    "tsx": "^4.23.0",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "ultracite": "7.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
