{
  "name": "@mdsync/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./workspaces": {
      "types": "./dist/workspaces.d.mts",
      "default": "./dist/workspaces.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "pack:dry-run": "npm pack --dry-run --json",
    "prepack": "pnpm run build",
    "test": "pnpm run check-types && tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mdsync/config": "workspace:*",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
