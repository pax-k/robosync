{
  "name": "@mdsync/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc -b",
    "db:generate": "drizzle-kit generate",
    "test": "pnpm run check-types && tsx --test src/*.test.ts src/**/*.test.ts",
    "test:integration": "pnpm run test"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@mdsync/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "libsql": "0.5.29",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mdsync/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
