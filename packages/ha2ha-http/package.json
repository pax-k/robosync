{
  "name": "@mdsync/ha2ha-http",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/conformance.ts"
    },
    "./cli": {
      "default": "./src/cli.ts"
    },
    "./conformance": {
      "default": "./src/conformance.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc -b",
    "conformance": "tsx src/cli.ts",
    "test": "pnpm run check-types && tsx --test src/**/*.test.ts",
    "test:integration": "pnpm run test"
  },
  "dependencies": {
    "@mdsync/ha2ha-protocol": "workspace:*"
  },
  "devDependencies": {
    "@mdsync/config": "workspace:*",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
