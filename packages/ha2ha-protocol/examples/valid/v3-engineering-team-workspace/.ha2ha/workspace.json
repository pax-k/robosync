{
  "protocol": "ha2ha",
  "protocolVersion": "1.0.0",
  "workspaceId": "v3-engineering-team-workspace",
  "title": "v3 Engineering Team Workspace",
  "paths": {
    "manifestMarkdown": "HA2HA.md",
    "status": "STATUS.md",
    "participants": "participants/",
    "tasks": "tasks/",
    "evidence": "evidence/",
    "decisions": "decisions/",
    "logs": "logs/",
    "workspaceManifest": ".ha2ha/workspace.json"
  },
  "capabilities": ["raw-read", "file-write", "events", "file-history"],
  "profiles": [
    "ha2ha-validation",
    "ha2ha-methods",
    "ha2ha-coordination",
    "ha2ha-trust",
    "ha2ha-evidence-review",
    "ha2ha-governance",
    "ha2ha-engineering"
  ],
  "routes": {
    "rawListing": "/w/v3-engineering-team-workspace/raw",
    "rawFile": "/w/v3-engineering-team-workspace/raw/{path}",
    "file": "/api/workspaces/v3-engineering-team-workspace/files",
    "tree": "/api/workspaces/v3-engineering-team-workspace/tree"
  },
  "conflictPolicy": "baseVersion-required",
  "schemaVersions": {
    "workspace": "1.0.0",
    "v3": "3.0.0"
  }
}
