{
  "protocol": "ha2ha",
  "protocolVersion": "1.0.0",
  "workspaceId": "v3-evidence-review-only",
  "title": "v3 Evidence Review Only",
  "paths": {
    "manifestMarkdown": "HA2HA.md",
    "status": "STATUS.md",
    "participants": "participants/",
    "tasks": "tasks/",
    "evidence": "evidence/",
    "decisions": "decisions/",
    "logs": "logs/",
    "workspaceManifest": ".ha2ha/workspace.json"
  },
  "capabilities": ["raw-read", "file-write"],
  "profiles": ["ha2ha-evidence-review"],
  "routes": {
    "rawListing": "/w/v3-evidence-review-only/raw",
    "rawFile": "/w/v3-evidence-review-only/raw/{path}"
  },
  "conflictPolicy": "baseVersion-required"
}
