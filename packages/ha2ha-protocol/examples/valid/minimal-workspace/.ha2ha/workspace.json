{
  "protocol": "ha2ha",
  "protocolVersion": "1.0.0",
  "workspaceId": "minimal-workspace",
  "title": "Minimal HA2HA Workspace",
  "paths": {
    "manifestMarkdown": "HA2HA.md",
    "status": "STATUS.md",
    "participants": "participants/",
    "tasks": "tasks/",
    "evidence": "evidence/",
    "decisions": "decisions/",
    "logs": "logs/",
    "workspaceManifest": ".ha2ha/workspace.json"
  },
  "capabilities": ["raw-read", "file-write"],
  "routes": {
    "rawListing": "/w/minimal-workspace/raw",
    "rawFile": "/w/minimal-workspace/raw/{path}",
    "file": "/api/workspaces/minimal-workspace/files",
    "tree": "/api/workspaces/minimal-workspace/tree"
  },
  "conflictPolicy": "baseVersion-required",
  "schemaVersions": {
    "workspace": "1.0.0",
    "task": "1.0.0",
    "evidence": "1.0.0"
  }
}
