{
  "name": "@ha2ha/protocol",
  "version": "0.1.0",
  "description": "HA2HA protocol constants, schemas, examples, validation API, validator CLI, and v3 profile layer.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://ha2ha.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pax-k/ha2ha-mdsync.git",
    "directory": "packages/ha2ha-protocol"
  },
  "bugs": {
    "url": "https://github.com/pax-k/ha2ha-mdsync/issues"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./constants": {
      "types": "./dist/constants.d.mts",
      "default": "./dist/constants.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.mts",
      "default": "./dist/schemas.mjs"
    },
    "./validator": {
      "types": "./dist/validator.d.mts",
      "default": "./dist/validator.mjs"
    },
    "./v3-constants": {
      "types": "./dist/v3-constants.d.mts",
      "default": "./dist/v3-constants.mjs"
    },
    "./v3-schemas": {
      "types": "./dist/v3-schemas.d.mts",
      "default": "./dist/v3-schemas.mjs"
    },
    "./v3-validator": {
      "types": "./dist/v3-validator.d.mts",
      "default": "./dist/v3-validator.mjs"
    },
    "./examples/*": {
      "default": "./examples/*"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "bin": {
    "ha2ha-validate": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b && pnpm run build",
    "pack:dry-run": "npm pack --dry-run --json",
    "prepack": "pnpm run build",
    "test": "pnpm run check-types && tsx --test src/**/*.test.ts",
    "validate": "tsx src/cli.ts"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mdsync/config": "workspace:*",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
