{
  "name": "@mdsync/skills",
  "version": "0.1.0",
  "description": "Installable MDSync hosted product agent skill package.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://mdsync-web-pax.pax.workers.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pax-k/robosync.git",
    "directory": "packages/mdsync-skills"
  },
  "bugs": {
    "url": "https://github.com/pax-k/robosync/issues"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./runtime": {
      "types": "./dist/runtime.d.mts",
